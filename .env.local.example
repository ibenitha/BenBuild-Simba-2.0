# Simba 2.0 Environment Variables
# Copy this file to .env.local and fill in your actual values

# ============================================
# Supabase Configuration
# ============================================
# Get these from: https://supabase.com → Your Project → Settings → API

# Your Supabase project URL (e.g., https://xxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url

# Your Supabase anon/public key (starts with eyJ...)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ============================================
# Groq API Configuration
# ============================================
# Get this from: https://console.groq.com → API Keys → Create API Key

# Your Groq API key (starts with gsk_...)
GROQ_API_KEY=your_groq_api_key

# ============================================
# Notes
# ============================================
# - Never commit .env.local to version control
# - Keep your API keys secure
# - Use different keys for development and production
# - Restart the dev server after changing these values
